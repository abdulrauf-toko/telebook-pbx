  <extension name="tokolab_outbound">
    <condition field="destination_number" expression="^(0[0-9]+)$">
      <action application="set" data="effective_caller_id_number=2138722005"/>
      <action application="set" data="effective_caller_id_name=TOKOLAB"/>
      <!-- <action application="set" data="sip_sticky_contact=true"/> -->
      <action application="set" data="absolute_codec_string=PCMU,PCMA"/>
      <action application="set" data="media_webrtc=false"/>
      <action application="set" data="rtp_secure_media=false"/>
      <action application="set" data="inherit_codec=false"/>
      <action application="set" data="bypass_media=false"/>
      <action application="set" data="ep_codec_string=PCMU,PCMA"/>
      <action application="set" data="codec_string=PCMU,PCMA"/>
      <action application="bridge" data="{origination_caller_id_number=2138722005}sofia/gateway/tokolab_trunk/$1"/>
    </condition>
  </extension>

  <extension name="echo_test">
    <condition field="destination_number" expression="^9196$">
      <!-- <action application="set" data="absolute_codec_string=PCMU,PCMA"/> -->
      <!-- <action application="answer"/> -->
      <!-- <action application="set" data="rtp_patch_media_ip=10.200.173.37"/> -->
      <action application="echo"/>
    </condition>
  </extension>
  </context>
</include>